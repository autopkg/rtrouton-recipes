<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Downloads the latest version of Notepad++ and creates a package.</string>
	<key>Identifier</key>
	<string>com.github.rtrouton.pkg.NotepadPlusPlus</string>
	<key>Input</key>
	<dict>
         <key>NAME</key>
         <string>Notepad Plus Plus</string>
         <key>SOFTWARETITLE1</key>
         <string>Notepad</string>
         <key>SOFTWARETITLE2</key>
         <string>Plus</string>
         <key>SOFTWARETITLE3</key>
         <string>Plus</string>
	</dict>
	<key>MinimumVersion</key>
	<string>2.3</string>
	<key>ParentRecipe</key>
	<string>com.github.rtrouton.download.NotepadPlusPlus</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>app_path</key>
				<string>%pathname%/Notepad++.app</string>
				<key>pkg_path</key>
				<string>%RECIPE_CACHE_DIR%/%SOFTWARETITLE1%_%SOFTWARETITLE2%_%SOFTWARETITLE3%_%version%.pkg</string>
			</dict>
			<key>Processor</key>
			<string>AppPkgCreator</string>
		</dict>
	</array>
</dict>
</plist>
